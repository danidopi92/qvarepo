[Unit]
Description=QvaTel Billing Gunicorn
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/qvatel-billing
EnvironmentFile=/opt/qvatel-billing/.env
ExecStart=/opt/qvatel-billing/.venv/bin/gunicorn -c deployment/gunicorn/gunicorn.conf.py config.wsgi:application
Restart=always

[Install]
WantedBy=multi-user.target
